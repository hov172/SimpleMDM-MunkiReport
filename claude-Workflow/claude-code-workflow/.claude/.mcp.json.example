{
  "_comment": "Rename to .mcp.json and fill in your credentials. Commit to git (no secrets in values — use env vars). See https://docs.anthropic.com/en/docs/claude-code/mcp",
  "mcpServers": {
    "slack": {
      "type": "http",
      "url": "https://slack.mcp.anthropic.com/mcp",
      "_comment": "Slack MCP — paste bug threads, Claude reads and fixes. Auth via browser on first use."
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "_comment": "GitHub MCP — PR management, issue linking, compounding review"
    }
  },
  "_optional_servers": {
    "sentry": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server"],
      "env": {
        "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}",
        "SENTRY_ORG": "_fill in_"
      }
    },
    "linear": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@linear/mcp-server"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    }
  }
}
